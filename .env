# X11 display for GUI tools
DISPLAY=:1


# DeepStream configurations
GIE_0_CONFIG=/deepstream_app/deepstream/config/config_pgie_yolo_detct.txt
GIE_1_CONFIG=/deepstream_app/deepstream/config/config_pgie_yolo_seg.txt
WIDTH_MODEL=640
HEIGHT_MODEL=640
DS_BATCHED_PUSH_TIMEOUT=80666
USE_NEW_NVSTREAMMUX=yes
DS_TRACKER=NvDCF


# Pick one:
# DS_TRACKER=IOU           # fastest, no GPU
# DS_TRACKER=NvSORT        # fast, no GPU (default)
# DS_TRACKER=NvDCF         # GPU, handles occlusion
# DS_TRACKER=NvDeepSORT    # GPU, Re-ID (needs model setup)
# DS_TRACKER=off           # disable tracker entirely