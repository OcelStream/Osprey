# Python
__pycache__/
*.py[cod]
*.egg-info/
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# TensorRT engines — generated locally at runtime, GPU/TensorRT-specific
*.engine
# (Sample ONNX models under server/deepstream/models/ ARE tracked.)

# Compiled C/C++ objects (the checked-in .so parsers are intentionally kept;
# only transient build intermediates are ignored)
*.o
*.obj

# Runtime IPC sockets (shared volume is recreated on each run)
sockets/*.sock

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store

# Logs
*.log
